# ============================================================
# SANTÉ FACILE — Variables d'environnement (Module 1)
# Copiez ce fichier vers .env puis renseignez vos valeurs :
#   cp .env.example .env
# Valeurs disponibles dans : Supabase Dashboard > Project Settings > API
# ============================================================

# URL de votre projet Supabase (ex : https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=https://VOTRE-PROJET.supabase.co

# Clé publique "anon" (JAMAIS la clé service_role côté frontend !)
VITE_SUPABASE_ANON_KEY=VOTRE_CLE_ANON_PUBLIQUE

# (Optionnel) Serveur Jitsi dédié pour la production — défaut : https://meet.jit.si
# VITE_JITSI_URL=https://jitsi.votre-domaine.ci
